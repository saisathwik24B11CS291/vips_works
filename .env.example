PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/vips_db?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret

# Google login client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Gmail SMTP for OTP and password-change emails.
# Use a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_google_app_password
SMTP_FROM=VIPs <youraddress@gmail.com>

# Recommended for Render Free because SMTP ports are blocked there.
# Create an API key at https://resend.com and verify a sender/domain.
RESEND_API_KEY=re_xxxxxxxxx
MAIL_FROM=VIPs <onboarding@resend.dev>
